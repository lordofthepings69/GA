generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  TeaTaster
  SeniorTaster
  CataloguingTeam
  Salesperson
  WarehouseStaff
  Finance
  Management
  Admin
}

enum Region {
  NuwaraEliya
  Dimbula
  Uva
  Sabaragamuwa
  Kandy
  Ruhuna
}

enum Elevation {
  HG
  MG
  LG
}

enum Grade {
  BOP
  BOPF
  OP
  OP1
  OPA
  Pekoe
  Dust1
  Dust
  BF
  FNGS1
  FNGS
  PD
  PEK
}

enum LotStatus {
  Active
  Withdrawn
  Passed
  Sold
}

enum TastingStatus {
  Draft
  Submitted
  Approved
  Overridden
}

enum ResultStatus {
  Sold
  Unsold
  Passed
}

enum DispatchStatus {
  Sent
  Received
  Lost
  Disputed
}

enum RecipientType {
  Buyer
  InternalTaster
  Seller
}

enum LiquorBrightness {
  Bright
  Good
  Fair
  Dull
}

enum LiquorStrength {
  Strong
  Medium
  Light
  Thin
}

enum LiquorBriskness {
  Brisk
  Good
  Fair
  Lacking
}

enum LiquorFlavor {
  Excellent
  Good
  Fair
  Plain
  Off
}

enum LiquorAroma {
  Distinctive
  Good
  Fair
  Plain
}

enum OverallQuality {
  Outstanding
  VeryGood
  Good
  Fair
  BelowAverage
  Poor
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(TeaTaster)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  tastingRecords   TastingRecord[]
  approvedTastings TastingRecord[] @relation("ApprovedBy")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Seller {
  id          String   @id @default(cuid())
  sellerCode  String   @unique
  companyName String
  contactName String?
  email       String?
  phone       String?
  address     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lots Lot[]
}

model Buyer {
  id          String   @id @default(cuid())
  buyerCode   String   @unique
  companyName String
  contactName String?
  email       String?
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  auctionResults AuctionResult[]
}

model Lot {
  id                String    @id @default(cuid())
  catalogueNumber   String    @unique
  saleNumber        String
  lotNumber         String
  saleDate          DateTime
  sellerId          String
  estateName        String
  factory           String?
  division          String?
  region            Region
  elevation         Elevation
  grade             Grade
  numPackages       Int
  grossWeight       Decimal   @db.Decimal(10, 2)
  netWeight         Decimal   @db.Decimal(10, 2)
  dateOfManufacture DateTime
  warehouseLocation String?
  adviceNoteNumber  String?
  upsettingPrice    Decimal?  @db.Decimal(10, 2)
  lotStatus         LotStatus @default(Active)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  seller           Seller           @relation(fields: [sellerId], references: [id])
  tastingRecords   TastingRecord[]
  auctionResult    AuctionResult?
  sampleDispatches SampleDispatch[]

  @@index([estateName, grade])
  @@index([saleDate])
  @@index([region, grade])
  @@index([saleNumber])
}

model TastingRecord {
  id         String   @id @default(cuid())
  lotId      String
  tasterId   String
  dateTasted DateTime @default(now())

  dryLeafAppearanceScore  Int?
  dryLeafAppearanceNotes  String? @db.Text
  dryLeafColorScore       Int?
  dryLeafColorNotes       String? @db.Text
  dryLeafUniformityScore  Int?
  dryLeafUniformityNotes  String? @db.Text
  dryLeafAromaScore       Int?
  dryLeafAromaNotes       String? @db.Text

  infusionBrightnessScore Int?
  infusionBrightnessNotes String? @db.Text
  infusionColorScore      Int?
  infusionColorNotes      String? @db.Text
  infusionEvennessScore   Int?
  infusionEvennessNotes   String? @db.Text

  liquorBrightness      LiquorBrightness?
  liquorBrightnessNotes String?           @db.Text
  liquorColor           String?
  liquorStrength        LiquorStrength?
  liquorBriskness       LiquorBriskness?
  liquorFlavor          LiquorFlavor?
  liquorAroma           LiquorAroma?
  overallQuality        OverallQuality?
  overallQualityNotes   String?           @db.Text

  priceRecommendation Decimal? @db.Decimal(10, 2)
  tastingNotes        String?  @db.Text

  status         TastingStatus @default(Draft)
  overrideReason String?       @db.Text
  approvedById   String?
  approvedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lot        Lot   @relation(fields: [lotId], references: [id])
  taster     User  @relation(fields: [tasterId], references: [id])
  approvedBy User? @relation("ApprovedBy", fields: [approvedById], references: [id])

  @@index([lotId])
  @@index([tasterId])
  @@index([dateTasted])
}

model AuctionResult {
  id            String       @id @default(cuid())
  lotId         String       @unique
  saleNumber    String
  hammerPrice   Decimal?     @db.Decimal(10, 2)
  buyerId       String?
  resultStatus  ResultStatus
  postSaleNotes String?      @db.Text
  dateRecorded  DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  lot   Lot    @relation(fields: [lotId], references: [id])
  buyer Buyer? @relation(fields: [buyerId], references: [id])

  @@index([saleNumber])
  @@index([dateRecorded])
}

model SampleDispatch {
  id               String         @id @default(cuid())
  lotId            String
  recipientType    RecipientType
  recipientId      String
  dateDispatched   DateTime
  dateReceived     DateTime?
  sampleWeightSent Decimal?       @db.Decimal(8, 3)
  status           DispatchStatus @default(Sent)
  notes            String?        @db.Text
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  lot Lot @relation(fields: [lotId], references: [id])

  @@index([lotId])
  @@index([recipientId])
}
